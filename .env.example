# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn — https://www.linkedin.com/developers/apps
# Create an app, add redirect URL http://localhost:3333/callback, request "Share on LinkedIn" product.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Run `npm run auth-linkedin` to fill these in automatically:
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# GitHub — https://github.com/settings/tokens
# Classic PAT with `repo` + `workflow` scopes.
GH_PAGES_TOKEN=ghp_...
# Your repo in owner/repo format (used for local runs; GitHub Actions uses GITHUB_REPOSITORY automatically)
GITHUB_REPO=THOMAS-DYLAN/Linkedin-Poster

# The contact link that appears at the bottom of every generated page
YOUR_CONTACT_URL=https://yourwebsite.com/contact
